# Recommended for best quality. If the free tier runs out, AdaptED automatically
# falls back to built-in local transforms (demo keeps working).
# Get a key: https://aistudio.google.com/apikey
# No spaces around = — save this file, then restart: npm run dev
GEMINI_API_KEY=your_api_key_here
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
